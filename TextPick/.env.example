# Copy to .env and fill in your values

# Vercel AI Gateway key (https://ai-gateway.vercel.sh)
AI_GATEWAY_API_KEY=your_key_here

# Optional overrides:
# TEXTPICK_API_URL=https://ai-gateway.vercel.sh/v1   (default)
# TEXTPICK_MODEL=anthropic/claude-haiku-4.5          (default — fast & cheap)
# TEXTPICK_MODEL=anthropic/claude-sonnet-4.6         (better quality)
# TEXTPICK_MODEL=google/gemini-3-flash               (alternative)
# TEXTPICK_MODEL=openai/gpt-5-nano                   (cheapest)
